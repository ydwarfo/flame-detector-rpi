# Raspberry Pi deployment config
# Copy this file to .deploy.env and fill in your values
# .deploy.env is gitignored — never commit it

RPI_HOST=your-pi.example.com   # IP address or hostname
RPI_USER=pi                    # SSH username
RPI_PORT=22                    # SSH port (default: 22)
REMOTE_DIR=~/flame_detector    # Target directory on the Pi
SERVICE_NAME=flame-detector    # systemd service name (for --restart)
